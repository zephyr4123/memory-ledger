# 复制为 .env (已被 gitignore), 填入你的 key 后 `docker compose up --build`。

# 配了才是真 LLM 对话 (live)。不配则 api 以 mock 模式运行:
# 全栈仍可起, seed 数据 / 时光机 / 溯源都能看, 仅对话不写真记忆。
ANTHROPIC_API_KEY=

# 对话模型 (可选)
MEMORY_LEDGER_MODEL=claude-sonnet-4-6

# 可选: 宿主端口被其它服务占用时改这些 (默认 web 8080 / api 8000 / db 5433)
# WEB_PORT=8080
# API_PORT=8000
# DB_PORT=5433
