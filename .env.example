# 复制为 .env (已被 gitignore), 填好后 `docker compose up --build`。

# ── LLM 接入 (经 LiteLLM, 一套代码接任意 provider) ─────────────────────
# 配了 LLM_API_KEY 才是真 LLM 对话 (live); 不配则 api mock 模式 (全栈仍可起, 不写真记忆)。
LLM_API_KEY=

# 模型路由串 (LiteLLM 格式)。DeepSeek V4 Pro: deepseek/deepseek-v4-pro
#   其它例: openai/gpt-4o-mini · anthropic/claude-sonnet-4-6
#   接任意 OpenAI 兼容端点: 用 openai/<model> + 下面的 LLM_BASE_URL
LLM_MODEL=deepseek/deepseek-v4-pro

# 自定义 Base URL (可选): 接自建/第三方 OpenAI 兼容端点时填; 用官方 provider 前缀时留空。
#   例: LLM_MODEL=openai/deepseek-v4-pro  LLM_BASE_URL=https://api.deepseek.com
LLM_BASE_URL=

# ── 宿主端口 (可选, 被其它服务占用时改) ───────────────────────────────
# WEB_PORT=8080
# API_PORT=8000
# DB_PORT=5433
